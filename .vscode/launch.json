{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Débogueur Python : FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "jinja": true,
      "justMyCode": true
    }
  ]
}
